# =============================================================================
# FinWatch Zambia — .gitignore
# =============================================================================

# Environment variables — NEVER commit
.env
.env.local
.env.*.local

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
env/
venv/
.venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
*.egg
MANIFEST

# =============================================================================
# ML Artifacts — models are regenerated via ml/train.py
# =============================================================================
backend/ml/artifacts/*.pkl
backend/ml/artifacts/*.joblib
backend/ml/artifacts/*.json
backend/ml/artifacts/*.npy
backend/ml/artifacts/*.npz

# =============================================================================
# Datasets — downloaded separately, see data/README.md
# =============================================================================
data/*.csv
data/*.arff
data/*.xlsx
data/*.zip
data/*.gz

# =============================================================================
# Database files — generated at runtime
# =============================================================================
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# =============================================================================
# Jupyter Notebooks — checkpoints
# =============================================================================
.ipynb_checkpoints/
notebooks/.ipynb_checkpoints/

# =============================================================================
# Node / Next.js
# =============================================================================
node_modules/
.next/
out/
frontend/.next/
frontend/out/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# OS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# IDE
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# Logs
# =============================================================================
*.log
logs/

# =============================================================================
# Generated Reports
# =============================================================================
backend/reports/*.pdf
backend/reports/*.csv
backend/reports/*.zip
!backend/reports/.gitkeep
